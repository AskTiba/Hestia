generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ShopMaster Relations
  sales     Sale[]
  stockLogs StockLog[]

  // VibeCheck Relations
  reviews      Review[]
  crowdReports CrowdReport[]
}

model Place {
  id          String   @id @default(uuid())
  name        String
  description String?
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  address     String?
  contactInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  activities   PlaceActivity[]
  events       Event[]
  reviews      Review[]
  crowdReports CrowdReport[]
}

model Activity {
  id   String @id @default(uuid())
  name String @unique // e.g., "Swimming", "Chess"

  // Relations
  places PlaceActivity[]
}

model PlaceActivity {
  id         String   @id @default(uuid())
  placeId    String
  activityId String
  place      Place    @relation(fields: [placeId], references: [id])
  activity   Activity @relation(fields: [activityId], references: [id])

  @@unique([placeId, activityId])
}

model Event {
  id          String    @id @default(uuid())
  placeId     String
  title       String
  description String?
  type        String // e.g., "Sports", "Charity"
  startTime   DateTime
  endTime     DateTime?
  ticketPrice Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())

  place Place @relation(fields: [placeId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  placeId   String
  userId    String
  rating    Int      @default(5)
  comment   String?
  vibeTags  Json? // Array of tags like ["Quiet", "Friendly"]
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

enum VibeStatus {
  CHILLED
  ACTIVE
  PACKED
}

model CrowdReport {
  id        String     @id @default(uuid())
  placeId   String
  userId    String
  status    VibeStatus
  createdAt DateTime   @default(now())

  place Place @relation(fields: [placeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}


model Product {
  id            String            @id @default(uuid())
  name          String
  sku           String?           @unique
  barcode       String?           @unique
  description   String?
  buyingPrice   Decimal           @db.Decimal(12, 2)
  sellingPrice  Decimal           @db.Decimal(12, 2)
  currentStock  Int               @default(0)
  minStockLevel Int               @default(5)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  locations     ProductLocation[]
  saleItems     SaleItem[]
  stockLogs     StockLog[]
}

model Location {
  id          String  @id @default(uuid())
  name        String
  description String?
  shelves     Shelf[]
}

model Shelf {
  id               String            @id @default(uuid())
  name             String
  locationId       String
  productLocations ProductLocation[]
  location         Location          @relation(fields: [locationId], references: [id])
}

model ProductLocation {
  id        String  @id @default(uuid())
  productId String
  shelfId   String
  product   Product @relation(fields: [productId], references: [id])
  shelf     Shelf   @relation(fields: [shelfId], references: [id])

  @@unique([productId, shelfId])
}

model StockLog {
  id        String   @id @default(uuid())
  productId String
  userId    String
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Sale {
  id          String     @id @default(uuid())
  userId      String
  totalAmount Decimal    @db.Decimal(12, 2)
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
  items       SaleItem[]
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  quantity    Int
  priceAtSale Decimal @db.Decimal(12, 2)
  product     Product @relation(fields: [productId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id])
}

enum UserRole {
  OWNER
  STAFF
}
