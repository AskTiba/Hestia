// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sales      Sale[]
  stockLogs  StockLog[]
}

model Product {
  id               String   @id @default(uuid())
  name             String
  sku              String?  @unique // Stock Keeping Unit
  barcode          String?  @unique
  description      String?
  buyingPrice      Decimal  @db.Decimal(12, 2)
  sellingPrice     Decimal  @db.Decimal(12, 2)
  currentStock     Int      @default(0)
  minStockLevel    Int      @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  locations  ProductLocation[]
  stockLogs  StockLog[]
  saleItems  SaleItem[]
}

model Location {
  id          String   @id @default(uuid())
  name        String   // e.g., "Left Wall", "Back Wall", "Front Outside"
  description String?
  
  // Relations
  shelves     Shelf[]
}

model Shelf {
  id          String   @id @default(uuid())
  name        String   // e.g., "Shelf 1", "Top Row"
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  // Relations
  productLocations ProductLocation[]
}

model ProductLocation {
  id        String @id @default(uuid())
  productId String
  shelfId   String
  product   Product @relation(fields: [productId], references: [id])
  shelf     Shelf   @relation(fields: [shelfId], references: [id])

  @@unique([productId, shelfId]) // A product shouldn't be mapped to the same shelf twice
}

model StockLog {
  id          String   @id @default(uuid())
  productId   String
  userId      String
  quantity    Int      // Positive for added stock, negative for removals/corrections
  reason      String?  // e.g., "New Shipment", "Damaged Goods"
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Sale {
  id          String   @id @default(uuid())
  userId      String
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  items       SaleItem[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  priceAtSale Decimal @db.Decimal(12, 2) // Capture the price at the moment of sale

  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}
